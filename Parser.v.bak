module Parser (
    input        clk,
    input        rst_n,
    input  [7:0] uart_data,
    input        uart_ready,

    output reg [15:0] price_s1,
    output reg [15:0] price_s2,
    output reg        data_valid
);

    reg [1:0] byte_cnt;
    reg [31:0] shift_reg;

    always @(posedge clk or negedge rst_n) begin
        if (!rst_n) begin
            byte_cnt  <= 0;
            shift_reg <= 0;
            price_s1  <= 0;
            price_s2  <= 0;
            data_valid <= 0;
        end else begin
            data_valid <= 0;

            if (uart_ready) begin
                shift_reg <= {shift_reg[23:0], uart_data};
                byte_cnt <= byte_cnt + 1;

                if (byte_cnt == 3) begin
                    price_s1  <= shift_reg[31:16];
                    price_s2  <= shift_reg[15:0];
                    data_valid <= 1'b1;
                    byte_cnt <= 0;
                end
            end
        end
    end

endmodule