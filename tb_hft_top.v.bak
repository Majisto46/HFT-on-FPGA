`timescale 1ns/1ps

module tb_hft_top;

  // --------------------
  // Clock & Reset
  // --------------------
  reg clk;
  reg rst_n;

  // UART line (unused in SIM stub)
  reg uart_rx_line;

  // Outputs
  wire [15:0] current_price_s1;
  wire [15:0] current_price_s2;
  wire [31:0] s1_return_val;
  wire        calc_finished_pulse;

  // --------------------
  // DUT
  // --------------------
  hft_top dut (
    .clk(clk),
    .rst_n(rst_n),
    .uart_rx_line(uart_rx_line),
    .current_price_s1(current_price_s1),
    .current_price_s2(current_price_s2),
    .s1_return_val(s1_return_val),
    .calc_finished_pulse(calc_finished_pulse)
  );

  // --------------------
  // Clock Generator
  // 100 MHz clock
  // --------------------
  always #5 clk = ~clk;

  // --------------------
  // Stimulus
  // --------------------
  initial begin
    // init
    clk = 0;
    rst_n = 0;
    uart_rx_line = 1'b1; // idle UART

    // reset pulse
    #50;
    rst_n = 1;

    // run simulation
    #10000;
    $stop;
  end

endmodule